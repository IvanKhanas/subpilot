# =============================================================================
# tg-bot-service
# =============================================================================

TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING_TIMEOUT=30

# =============================================================================
# chat-service
# =============================================================================

OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# =============================================================================
# PostgreSQL (chat-service)
# =============================================================================

CHAT_DB_NAME=chat
CHAT_DB_USER=chat
CHAT_DB_PASSWORD=chat

# =============================================================================
# Redis
# =============================================================================

REDIS_PASSWORD=changeme
REDIS_MAX_MEMORY=256mb

# =============================================================================
# Chat history
# =============================================================================

CHAT_HISTORY_MAX_MESSAGES=20
CHAT_HISTORY_TTL=PT20M
