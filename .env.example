# =============================================================================
# tg-bot-service
# =============================================================================

TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING_TIMEOUT=30
TELEGRAM_BOT_SERVER_PORT=1991
CHAT_GRPC_ADDRESS=localhost:9090

SUPPORT_OPERATOR_TAG=unknown

# =============================================================================
# chat-service
# =============================================================================

OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
CHAT_SERVER_PORT=8082
CHAT_GRPC_SERVER_PORT=9090

REDIS_HOST=localhost
REDIS_PORT=6379
CHAT_HISTORY_MAX_MESSAGES=20
CHAT_HISTORY_TTL=PT20M

REDIS_PASSWORD=redis

# =============================================================================
# subscription-service
# =============================================================================

SUBSCRIPTION_DB_URL=jdbc:postgresql://localhost:5432/subscription
SUBSCRIPTION_DB_NAME=subscription
SUBSCRIPTION_DB_USER=subscription
SUBSCRIPTION_DB_PASSWORD=subscription
SUBSCRIPTION_GRPC_ADDRESS=localhost:9091
SUBSCRIPTION_GRPC_SERVER_PORT=9091

# =============================================================================
# tg-bot-service navigation
# =============================================================================

NAVIGATION_STACK_TTL=PT20M

# =============================================================================
# payment-service
# =============================================================================

PAYMENT_DB_URL=jdbc:postgresql://localhost:5432/payment
PAYMENT_DB_USER=payment
PAYMENT_DB_PASSWORD=payment
PAYMENT_SERVER_PORT=8084
PAYMENT_GRPC_SERVER_PORT=9094
PAYMENT_GRPC_ADDRESS=localhost:9094

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
