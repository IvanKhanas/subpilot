# =============================================================================
# tg-bot-service
# =============================================================================

TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING_TIMEOUT=30
TELEGRAM_POLLING_RETRY_DELAY_MS=5000
TELEGRAM_BOT_SERVER_PORT=1991

# =============================================================================
# chat-service / OpenAI
# =============================================================================

OPENAI_API_KEY=
OPENAI_MAX_COMPLETION_TOKENS=2048
CHAT_GRPC_SERVER_PORT=9090
CHAT_SERVER_PORT=8082

# =============================================================================
# gRPC channels
# =============================================================================

CHAT_GRPC_ADDRESS=localhost:9090
SUBSCRIPTION_GRPC_ADDRESS=localhost:9091
SUBSCRIPTION_GRPC_SERVER_PORT=9091
SUBSCRIPTION_SERVER_PORT=8083

# =============================================================================
# Redis
# =============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis
# REDIS_MAX_MEMORY=256mb  # used by infra/docker-compose.yml

# =============================================================================
# PostgreSQL (subscription-service)
# =============================================================================

POSTGRES_PASSWORD=postgres
SUBSCRIPTION_DB_NAME=subscription
SUBSCRIPTION_DB_USER=subscription
SUBSCRIPTION_DB_PASSWORD=subscription
# SUBSCRIPTION_DB_URL=jdbc:postgresql://localhost:5432/subscription

# =============================================================================
# subscription-service domain config
# =============================================================================

SUBSCRIPTION_FREE_QUOTA=10
SUBSCRIPTION_FREE_QUOTA_RESET_PERIOD=7d
SUBSCRIPTION_DEFAULT_MODEL=gpt-4o-mini

# =============================================================================
# Chat history / navigation
# =============================================================================

CHAT_HISTORY_MAX_MESSAGES=20
CHAT_HISTORY_TTL=PT20M
NAVIGATION_STACK_TTL=PT20M

# =============================================================================
# Support / retries
# =============================================================================

SUPPORT_OPERATOR_TAG=unknown
GRPC_RETRY_MAX_ATTEMPTS=3
GRPC_RETRY_INITIAL_BACKOFF_MS=200
GRPC_RETRY_BACKOFF_MULTIPLIER=3.0
